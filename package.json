{
  "name": "lucid-rents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "mkdir -p .next && (uname | grep -q Darwin && xattr -w com.apple.fileprovider.ignore#P 1 .next 2>/dev/null || true) && next dev --turbopack",
    "build": "next build",
    "generate-sitemaps": "node scripts/generate-sitemaps.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:render": "remotion render remotion/index.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.2",
    "@vercel/functions": "^3.4.3",
    "ai": "^6.0.141",
    "cheerio": "^1.2.0",
    "fflate": "^0.8.2",
    "framer-motion": "^12.38.0",
    "geist": "^1.3.1",
    "jose": "^6.2.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.0",
    "resend": "^4.1.2",
    "rss-parser": "^3.13.0",
    "workflow": "^4.2.0-beta.73",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4",
    "xlsx": "^0.18.5"
  }
}
